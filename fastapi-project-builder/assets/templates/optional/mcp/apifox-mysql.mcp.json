{
  "mcpServers": {
    "apifox": {
      "command": "npx",
      "args": [
        "-y",
        "apifox-openapi-mcp@latest",
        "--token",
        "__APIFOX_TOKEN__",
        "--project-id",
        "__APIFOX_PROJECT_ID__"
      ]
    },
    "mysql": {
      "command": "npx",
      "args": [
        "-y",
        "@benborla29/mcp-server-mysql"
      ],
      "env": {
        "MYSQL_HOST": "__MYSQL_HOST__",
        "MYSQL_PORT": "__MYSQL_PORT__",
        "MYSQL_USER": "__MYSQL_USER__",
        "MYSQL_PASS": "__MYSQL_PASSWORD__",
        "MYSQL_DB": "__MYSQL_DATABASE__"
      }
    }
  }
}
